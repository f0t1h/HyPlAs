Bootstrap: oras
From: community.wave.seqera.io/library/blast_diamond_hmmer_infernal_pruned:b4a936a29579bed2

%files
    external/unicycler-modified-for-hyplas /opt/unicycler-modified-for-hyplas
    src /opt/hyplas/src
    Makefile /opt/hyplas/Makefile
    configure /opt/hyplas/configure

%post
    apt-get update && \
        apt-get install -y --no-install-recommends build-essential python3-dev zlib1g-dev pigz && \
        rm -rf /var/lib/apt/lists/*

    conda install -y -c bioconda -c conda-forge fastp chopper multiqc nanoplot quast && conda clean -afy

    cd /opt/unicycler-modified-for-hyplas && pip install --no-cache-dir .

    cd /opt/hyplas && ./configure --prefix=/usr/local && make -j$(nproc) && make install

    rm -rf /opt/unicycler-modified-for-hyplas /opt/hyplas

%labels
    Author HyPlAs
    Description HyPlAs container
